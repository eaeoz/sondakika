{
  "name": "sondakika",
  "version": "2.0.0",
  "description": "Modern Electron-based news reader with RSS feeds",
  "main": "src/main/main.js",
  "author": {
    "name": "Sedat Ergoz",
    "email": "sedatergoz@gmail.com",
    "url": "https://github.com/eaeoz"
  },
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir"
  },
  "dependencies": {
    "blessed": "^0.1.81",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.sondakika.app",
    "productName": "Sondakika",
    "copyright": "Copyright © 2024 Sedat Ergoz",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    },
    "electronDownload": {
      "cache": "dist/electron-cache"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ]
  }
}
